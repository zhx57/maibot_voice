{
  "manifest_version": 2,
  "id": "Emilia-awa.maibot-mimotts-voice",
  "name": "MiMo TTS Voice Clone",
  "version": "1.5.2",
  "description": "MiMo TTS Voice Clone Plugin for MaiBot - AI语音回复插件，支持自定义音色克隆和风格控制",
  "author": {
    "name": "Emilia-awa",
    "url": "https://github.com/Emilia-awa"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/Emilia-awa/maibot-mimotts-voice",
    "homepage": "https://github.com/Emilia-awa/maibot-mimotts-voice"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "1.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "send.text",
    "send.custom",
    "send.record",
    "message.get_by_id",
    "chat.get_all_streams"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": ["zh-CN"]
  }
}