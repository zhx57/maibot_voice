{
  "manifest_version": 2,
  "id": "Emilia-awa.maibot-mimotts-voice",
  "name": "MiniMax Async TTS Voice",
  "version": "3.0.0",
  "description": "MiniMax Sync TTS Plugin for MaiBot - 基于MiniMax同步语音合成(/v1/t2a_v2, stream=false)的AI语音回复插件，单次请求返回完整音频，延迟更低，支持系统音色、音色复刻、情绪控制与风格映射",
  "author": {
    "name": "Emilia-awa",
    "url": "https://github.com/Emilia-awa"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/Emilia-awa/maibot-mimotts-voice",
    "homepage": "https://github.com/Emilia-awa/maibot-mimotts-voice"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "1.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "send.text",
    "send.custom",
    "send.record",
    "message.get_by_id",
    "chat.get_all_streams"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": ["zh-CN"]
  }
}